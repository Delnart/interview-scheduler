# Server
PORT=4000
NODE_ENV=development
# Public URL of the frontend (used for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL) — REQUIRED. Connection string:
#   local:   postgres://app:app@localhost:5432/interview
#   managed: take it from Neon / Supabase / Render (see README)
DATABASE_URL=
# Set to "true" for managed Postgres that requires SSL (Neon/Supabase/Render).
DATABASE_SSL=false

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=12h

# Default admin account, created automatically on first run if no users exist
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_now

# Password assigned to the seeded recruiter accounts on first run.
# Each recruiter should change this on first login (Профіль -> Змінити пароль).
DEFAULT_RECRUITER_PASSWORD=change_me_too

# Google Calendar OAuth (create credentials at https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/calendar/oauth/callback

# Default slot duration in minutes for generated interview slots.
# Recruiters select availability in 45-min interview + 15-min break blocks (08:00-21:00),
# so this should normally stay at 45.
DEFAULT_SLOT_DURATION_MINUTES=45

# Google Form responses sheet (optional). When set, the admin calendar shows each
# candidate's ПІБ, навчальна група and form answers, matched to a booking by
# email/Telegram. Disabled (and harmless) if left blank.
#  1. Create a service account in Google Cloud, enable the Google Sheets API.
#  2. Share the responses spreadsheet with the service account email (Viewer).
#  3. Set the spreadsheet id and the key (inline JSON or a path to the JSON file).
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_KEY=
# GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account.json
# Optional: sheet/tab + range. Defaults to the first sheet, columns A:ZZ.
# GOOGLE_SHEETS_RANGE=Form Responses 1!A:ZZ
# Optional column header overrides (otherwise auto-detected by header name).
# GOOGLE_SHEETS_EMAIL_COLUMN=Email
# GOOGLE_SHEETS_TELEGRAM_COLUMN=Telegram
# GOOGLE_SHEETS_NAME_COLUMN=ПІБ
# GOOGLE_SHEETS_GROUP_COLUMN=Група
