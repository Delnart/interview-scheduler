# Environment for docker-compose. Copy to .env and fill in real values:
#   cp .env.example .env
#
# .env is read automatically by `docker compose`. Never commit the real .env.

# Port the app is published on (the nginx frontend). The API is proxied at /api.
HTTP_PORT=8080

# Password for the bundled PostgreSQL container (docker compose builds DATABASE_URL
# from it automatically). REQUIRED. If you instead use a managed Postgres, set
# DATABASE_URL/DATABASE_SSL in backend/.env and you can ignore this.
POSTGRES_PASSWORD=

# REQUIRED. Long random string — generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=12h

# Public URL of the app (used for CORS and Google OAuth redirects).
# Must match HTTP_PORT above, or your real domain in production.
FRONTEND_URL=http://localhost:8080

# Default admin account, created on first run if the DB is empty. REQUIRED.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Password set for every seeded recruiter on first run. REQUIRED.
# Each recruiter should change it on first login.
DEFAULT_RECRUITER_PASSWORD=

# Google Calendar OAuth (optional — leave blank to disable the integration).
# In Docker the callback goes through the frontend proxy, so the redirect URI is:
#   <FRONTEND_URL>/api/calendar/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Slot length in minutes (matches the 45-min interview grid).
DEFAULT_SLOT_DURATION_MINUTES=45

# Google Form responses sheet (optional) — lets the admin calendar show each
# candidate's ПІБ, group and form answers, matched by email/Telegram.
# Share the sheet with the service account email (Viewer), then set:
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_KEY=
# GOOGLE_SHEETS_RANGE=Form Responses 1!A:ZZ
